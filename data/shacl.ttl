@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix cn:     <https://collectienederland.nl/shapes/> .

# Type checking toevoegen voor dingen zoals als DefinedTerm
# Check dat iets niet een blank node is

#################################################
# Er moet of een naam of een additional type aanwezig zijn
#################################################
cn:CreativeWorkShapeNameAdditionalType
    a              sh:NodeShape ;
    sh:name "schema:CreativeWork: Name/AdditionalType ontbreekt" ;
    sh:description "Een object moet een schema:name of schema:additionalType hebben" ;
    sh:targetClass schema:CreativeWork ;
    sh:or          ( [ sh:property [ sh:path     schema:name ;
                                     sh:minCount 1 ; ] ]
                     [ sh:property [ sh:path     schema:additionalType ;
                                     sh:minCount 1 ;
                                     sh:nodeKind sh:IRI ; ] ]
                   ) ;
    sh:severity    sh:Violation ;
    sh:message     "Keuzeveld 1 (ERROR): voeg een titel (schema:name) of objecttype (schema:additionalType als URI) toe." .

#################################################
# Geef een warning als er geen afbeelding is
#################################################
cn:CreativeWorkShapeMediaObject
    a              sh:NodeShape ;
    sh:targetClass schema:CreativeWork ;
    sh:name "schema:CreativeWork: MediaObject niet compleet" ;
    sh:description "Het is belangrijk dat wanneer er een media object bestaat, dat deze dan ook een content URL bevat." ;
    sh:property    [ sh:path schema:associatedMedia ;
                     sh:node [ sh:property [ sh:path     schema:contentUrl ;
                                             sh:nodeKind sh:IRI ;
                                             sh:minCount 1 ;
                                             sh:message  "WARNING: 'schema:contentUrl' (URL van afbeelding) ontbreekt bij associatedMedia." ;
                                             sh:severity sh:Warning ; ] ] ;
                   ] .

#################################################
# Temporal coverage moet aanwezig zijn, en van het type integer of string zijn
#################################################
cn:CreativeWorkShapeTemporalCoverage
    a              sh:NodeShape ;
    sh:name "schema:CreativeWork: Temporal coverage typefout" ;
    sh:description "De temporal coverage dient aanwezig te zijn en van het type string of integer." ;
    sh:targetClass schema:CreativeWork ;
    sh:or          ( [ sh:property [ sh:path     schema:temporalCoverage ;
                                     sh:datatype xsd:integer ;
                                     sh:minCount 1 ; ] ]
                     [ sh:property [ sh:path     schema:temporalCoverage ;
                                     sh:datatype xsd:string ;
                                     sh:minCount 1 ; ] ]
                   ) ;
    sh:severity    sh:Violation ;
    sh:message     "Keuzeveld 2 (ERROR): voeg een datering toe (numeriek of tekst via schema:temporalCoverage)." .

#################################################
# De volgende velden zijn verplicht; publisher, license, identifier, landing page (laatste optioneel?)
#################################################
cn:CreativeWorkShapeFields
    a              sh:NodeShape ;
    sh:targetClass schema:CreativeWork ;
    sh:name "schema:CreativeWork: Verplichte velden ontbreken" ;
    sh:description "De volgende velden zijn verplicht: schema:publisher, schema:license, schema:identifier, schema:url" ;
    sh:property    [ sh:path     schema:publisher ;
                     sh:minCount 1 ;
                     sh:severity sh:Violation ;
                     sh:message  "ERROR: 'schema:publisher' (instelling/dataprovider) is verplicht." ; ] ;

    sh:property    [ sh:path     schema:license ;
                     sh:minCount 1 ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Violation ;
                     sh:message  "ERROR: 'schema:license' is verplicht en moet een URI zijn." ; ] ;

    sh:property    [ sh:path     schema:identifier ;
                     sh:minCount 1 ;
                     sh:severity sh:Violation ;
                     sh:message  "ERROR: 'schema:identifier' (PID of identificatie) is verplicht." ; ] ;

    sh:property    [ sh:path     schema:url ;
                     sh:minCount 1 ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Violation ;
                     sh:message  "ERROR: een URL naar de record bij de bronhouder (schema:url) is verplicht." ; ] .


#################################################
# Tenminste 2/5 van deze velden moeten aanwezig zijn
#################################################
cn:CreativeWorkShapeCombined
    a              sh:NodeShape ;
    sh:name "schema:CreativeWork: Combinatie van verplichte velden ontbreken" ;
    sh:description "Tenminste 2 van deze 5 velden moeten gedefineerd zijn: schema:material, schema:size, schema:creator, schema:description, and schema:locationCreated" ;
    sh:targetClass schema:CreativeWork ;
    sh:severity    sh:Violation ;
    sh:or          (
                   # Combinations of 2 out of 5 that must pass
                   [ sh:and ( [ sh:property [ sh:path schema:material ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:size ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:material ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:creator ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:material ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:description ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:material ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:locationCreated ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:size ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:creator ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:size ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:description ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:size ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:locationCreated ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:creator ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:description ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:creator ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:locationCreated ; sh:minCount 1 ; ] ] ) ]
                   [ sh:and ( [ sh:property [ sh:path schema:description ; sh:minCount 1 ; ] ]
                              [ sh:property [ sh:path schema:locationCreated ; sh:minCount 1 ; ] ] ) ]
                   ) ;

    sh:property    [ sh:path     schema:material ;
                     sh:minCount 1 ;
                     sh:severity sh:Info ;
                     sh:message  "schema:material niet gedefineerd, is niet altijd verplicht" ; ] ;
    sh:property    [ sh:path     schema:size ;
                     sh:minCount 1 ;
                     sh:severity sh:Info ;
                     sh:message  "schema:size niet gedefineerd, is niet altijd verplicht" ; ] ;
    sh:property    [ sh:path     schema:creator ;
                     sh:minCount 1 ;
                     sh:severity sh:Info ;
                     sh:message  "schema:creator niet gedefineerd, is niet altijd verplicht" ; ] ;
    sh:property    [ sh:path     schema:description ;
                     sh:minCount 1 ;
                     sh:severity sh:Info ;
                     sh:message  "schema:description niet gedefineerd, is niet altijd verplicht" ; ] ;
    sh:property    [ sh:path     schema:locationCreated ;
                     sh:minCount 1 ;
                     sh:severity sh:Info ;
                     sh:message  "schema:locationCreated niet gedefineerd, is niet altijd verplicht" ; ] .