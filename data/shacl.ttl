@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix cn:     <https://collectienederland.nl/shapes/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

cn:CreativeWorkNameAdditionalTypePassOne
    a              sh:NodeShape ;
    sh:name        "schema:CreativeWork: schema:name en schema:additionalType ontbreken beiden, of zijn onjuist gedefineerd." ;
    sh:description "schema:name en schema:additionalType ontbreken" ;
    sh:targetClass schema:CreativeWork ;
    sh:or          ( [ sh:property [ sh:path       schema:name ;
                                     sh:minCount   1 ; ] ]
                     [ sh:property [ sh:path     schema:additionalType ;
                                     sh:minCount 1 ; ] ] ) ;
    sh:severity    sh:Violation ;
.
cn:CreativeWorkMandatoryAttributes
    a              sh:NodeShape ;
    sh:targetClass schema:CreativeWork ;
    sh:name        "schema:CreativeWork: verplicht veld ontbreekt" ;
    sh:description "veld ontbreekt" ;
    sh:property    [ sh:path schema:name ;
                     sh:minCount 1;
                     sh:severity sh:Warning; ] ;
    sh:property    [ sh:path schema:description ;
                     sh:minCount 1;
                     sh:severity sh:Warning; ] ;
    sh:property    [ sh:path schema:creator ;
                     sh:minCount 1;
                     sh:severity sh:Warning; ] ;
    sh:property    [ sh:path     schema:additionalType ;
                     sh:minCount 1 ;
                     sh:severity sh:Warning ; ] ;
    sh:property    [ sh:path     schema:license ;
                     sh:minCount 1 ;
                     sh:severity sh:Violation ; ] ;
    sh:property    [ sh:path     schema:mainEntityOfPage ;
                     sh:minCount 1 ;
                     sh:severity sh:Violation ; ] ;
    sh:property    [ sh:path     schema:isPartOf ;
                     sh:minCount 1 ;
                     sh:severity sh:Warning ; ] ;
    sh:property    [ sh:path     schema:associatedMedia ;
                     sh:minCount 1 ;
                     sh:severity sh:Warning ; ] ;
    sh:property    [ sh:path     schema:sdDatePublished ;
                     sh:minCount 1 ;
                     sh:severity sh:Violation ; ] ; .

cn:CreativeWorkMaxCount
    a              sh:NodeShape ;
    sh:targetClass schema:CreativeWork ;
    sh:name        "schema:CreativeWork: verplicht veld komt te vaak voor" ;
    sh:description "veld komt te vaak voor" ;
    sh:property    [ sh:path schema:name ;
                     sh:maxCount 1;
                     sh:severity sh:Violation; ] ;
    sh:property    [ sh:path     schema:license ;
                     sh:maxCount 1 ;
                     sh:severity sh:Violation ; ] ;
    sh:property    [ sh:path     schema:associatedMedia ;
                     sh:maxCount 1 ;
                     sh:severity sh:Violation ; ] ;
    sh:property    [ sh:path     schema:dateCreated ;
                     sh:maxCount 1 ;
                     sh:severity sh:Warning ; ] ;
.

cn:CreativeWorkType
    a              sh:NodeShape ;
    sh:targetClass schema:CreativeWork ;
    sh:name        "schema:CreativeWork: veldtype is incorrect" ;
    sh:description "veldtype incorrect" ;
    sh:property    [ sh:path     schema:name ;
                     sh:datatype   rdf:langString ;
                     sh:uniqueLang true ;
                     sh:severity sh:Warning ;
                   ] ;
    sh:property    [ sh:path     schema:additionalType ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning ;
                   ] ;
    sh:property    [ sh:path     schema:license ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Violation ;
                   ] ;
    sh:property    [ sh:path     schema:mainEntityOfPage ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Violation ;
                   ] ;
    sh:property    [ sh:path     schema:isPartOf ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning ;
                   ] ;
    sh:property    [ sh:path     schema:associatedMedia ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning ;
                   ] ;
    sh:property    [ sh:path     schema:sdDatePublished ;
                     sh:severity sh:Violation ;
                     sh:pattern  "^\\d{4}-\\d{2}-\\d{2}$" ;
                     sh:description "vorm moet 'YYYY-MM-DD' zijn"
                   ] ;
    sh:property    [ sh:path schema:dateCreated ;
                     sh:pattern "^\\d{4}(-\\d{2}(-\\d{2})?)?$" ;
                     sh:severity sh:Warning;
                     sh:description "dateCreated moet bestaan uit een v/d volgende formats: 'YYYY-MM-DD', 'YYYY-MM', of 'YYYY'"
                   ] ;
    sh:property    [ sh:path schema:temporal ;
                     sh:dataType xsd:string;
                     sh:severity sh:Info;
                   ] ;
    sh:property    [ sh:path schema:creator ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning;
                   ] ;
    sh:property    [ sh:path schema:description ;
                     sh:dataType rdf:langString;
                     sh:severity sh:Warning;
                   ] ;
    sh:property    [ sh:path schema:material ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning;
                   ] ;
    sh:property    [ sh:path schema:size ;
                     sh:dataType xsd:String ;
                     sh:severity sh:Warning;
                   ] ;
    sh:property    [ sh:path schema:locationCreated ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning;
                   ];
    sh:property    [ sh:path schema:copyrightHolder ;
                     sh:nodeKind sh:IRI ;
                     sh:severity sh:Warning;
                   ];
.

cn:MediaObjectShapeMinCount
    a sh:NodeShape ;
    sh:targetClass schema:MediaObject ;
    sh:name "schema:MediaObject: minCount" ;
    sh:description "veld ontbreekt" ;
    sh:property [ sh:path schema:contentUrl ;
                  sh:minCount 1;
                  sh:severity    sh:Violation ;
            ] ;
    sh:property [ sh:path schema:license ;
                  sh:minCount 1;
                  sh:severity    sh:Violation ;
                ] ;
    sh:property [ sh:path schema:thumbnailUrl ;
                  sh:minCount 1;
                  sh:severity    sh:Warning ;
                ] ;
    sh:property [ sh:path schema:url ;
                  sh:minCount 1;
                  sh:severity    sh:Warning ; ] ;
.

cn:MediaObjectShapeMaxCount
    a sh:NodeShape ;
    sh:targetClass schema:MediaObject ;
    sh:name "schema:MediaObject: maxCount" ;
    sh:description "veld komt te vaak voor" ;
    sh:property [ sh:path schema:contentUrl ;
                  sh:maxCount 1;
                  sh:severity    sh:Violation ; ] ;
    sh:property [ sh:path schema:license ;
                  sh:maxCount 1;
                  sh:nodeKind sh:IRI;
                  sh:severity    sh:Violation ; ] ;
    sh:property [ sh:path schema:thumbnailUrl ;
                  sh:maxCount 1;
                  sh:severity    sh:Warning ; ] ;
    sh:property [ sh:path schema:url ;
                  sh:maxCount 1;
                  sh:severity    sh:Warning ; ] ;
    sh:property [ sh:path schema:encodingFormat ;
                  sh:maxCount 1;
                  sh:severity    sh:Warning ; ] ;
.

cn:MediaObjectShapeType
    a sh:NodeShape ;
    sh:targetClass schema:MediaObject ;
    sh:name "schema:MediaObject: verkeerd type" ;
    sh:description "veld type incorrect" ;
    sh:property [ sh:path schema:license ;
                  sh:nodeKind sh:IRI;
                  sh:severity    sh:Violation ; ] ;
    sh:property [ sh:path schema:contentUrl ;
                  sh:nodeKind sh:IRI;
                  sh:severity  sh:Violation ; ] ;
    sh:property [ sh:path schema:url ;
                  sh:nodeKind sh:IRI;
                  sh:severity    sh:Warning ; ] ;
    sh:property [ sh:path schema:copyrightHolder ;
                  sh:nodeKind sh:IRI;
                  sh:severity    sh:Warning ; ] ;
    sh:property [ sh:path schema:copyrightHolder ;
                  sh:datatype xsd:string ;
                  sh:severity    sh:Warning ; ] ;
.

cn:PersonShapeMinCount
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:name "schema:Person: verplicht veld ontbreekt" ;
    sh:description "veld ontbreekt" ;
    sh:property [ sh:path schema:name ;
                  sh:minCount 1;
                  sh:severity    sh:Violation ;
                ] ;
.

cn:PersonShapeMaxCount
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:name "schema:Person: veld komt te vaak voor" ;
    sh:description "veld komt te vaak voor" ;
    sh:property [ sh:path schema:name ;
                  sh:maxCount 1;
                  sh:severity    sh:Violation ; ] ;
    sh:property [ sh:path schema:birthDate ;
                  sh:maxCount 1;
                  sh:severity  sh:Warning ; ] ;
    sh:property [ sh:path schema:deathDate ;
                  sh:maxCount 1;
                  sh:severity  sh:Warning ; ] ;
.

cn:PersonShapeType
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:name "schema:Person: veld type incorrect" ;
    sh:description "veld type incorrect" ;
    sh:property [ sh:path schema:name ;
                  sh:datatype rdf:langString ;
                  sh:severity    sh:Warning ; ] ;
    sh:property [ sh:path schema:birthDate ;
                  sh:pattern  "^\\d{4}-\\d{2}-\\d{2}$";
                  sh:severity  sh:Warning ; ] ;
    sh:property [ sh:path schema:deathDate ;
                  sh:pattern  "^\\d{4}-\\d{2}-\\d{2}$";
                  sh:severity  sh:Warning ; ] ;
.


