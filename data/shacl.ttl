                  sh:nodeKind sh:IRI;
                  sh:severity  sh:Warning ;
                ] ;
    sh:property [ sh:path schema:sameAs ;
                  sh:nodeKind sh:IRI;
                  sh:severity  sh:Warning ;
                ] ;
.

