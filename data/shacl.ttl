cn:OrganizationShapeType
    a sh:NodeShape ;
    sh:targetClass schema:Organization ;
    sh:name "schema:Organization: veld heeft verkeerd type" ;
    sh:description "veld type incorrect" ;
    sh:property [ sh:path schema:name ;
                  sh:datatype rdf:langString ;
                  sh:uniqueLang true ;
                  sh:severity    sh:Violation ;
                ] ;
