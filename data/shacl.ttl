cn:DefinedTermShapeType
    a sh:NodeShape ;
    sh:targetClass schema:DefinedTerm ;
    sh:name "schema:DefinedTerm: type veld incorrect" ;
    sh:description "type veld incorrect" ;
    sh:property [ sh:path schema:name ;
                  sh:datatype rdf:langString ;
                  sh:uniqueLang true ;
                  sh:severity    sh:Violation ;
                ] ;
    sh:property [ sh:path schema:sameAs ;
                  sh:severity  sh:Warning ;
                  sh:nodeKind sh:IRI;
                ] ;


.

cn:QuantativeValueMaxCount
    a sh:NodeShape ;
    sh:targetClass schema:QuantativeValue ;
    sh:description "veld komt te vaak voor";
    sh:property [ sh:path schema:value ;
                  sh:severity  sh:Warning ;
                  sh:maxCount 1;
                ] ;

.
cn:QuantativeValueType
    a sh:NodeShape ;
    sh:targetClass schema:QuantativeValue ;
    sh:description "veld type incorrect" ;
    sh:property [ sh:path schema:value ;
                  sh:dataType xsd:decimal;
                  sh:severity  sh:Warning ;
                ] ;
    sh:property [ sh:path schema:unitText ;
                  sh:dataType xsd:string ;
                  sh:severity  sh:Warning ;
                ] ;
.

# samengevoegd omdat het maar 1 type bevat die getoetst wordt
cn:PropertyValue
    a sh:NodeShape ;
    sh:targetClass schema:PropertyValue ;
    sh:property [ sh:path schema:value ;
                  sh:dataType xsd:string;
                  sh:severity  sh:Warning ;
                  sh:description "schema:value is geen string" ;
                ] ;
    sh:property [ sh:path schema:value ;
                  sh:severity  sh:Warning ;
                  sh:maxCount 1;
                  sh:description "schema:value komt te vaak voor" ;
                ] ;
.
